{
  "name": "marubatsu",
  "main": "worker/index.ts",
  "compatibility_date": "2025-06-01",
  // React のビルド成果物を静的配信。asset に無いパス (/ws) は Worker が処理する。
  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
  },
  // 1 ルーム = 1 Durable Object
  "durable_objects": {
    "bindings": [{ "name": "ROOM", "class_name": "RoomDO" }],
  },
  // SQLite-backed DO は無料プランでも使える
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["RoomDO"] }],
}
